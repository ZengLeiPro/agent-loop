{
  "$schemaVersion": 1,
  "name": "ralph-compound-prefilled",
  "description": "ralph-compound 变体:跳过 planner,直接进 Worker↔Judge 循环。前提:.agent-loop/spec.md 和 .agent-loop/prd.json 已由 workflow 或人工准备好。适用于多 sprint 项目里 sprint 启动场景(spec/prd 已离线整合产出)。",
  "concurrency": 1,
  "nodes": [
    {
      "id": "review-loop",
      "type": "loop",
      "inputs": [],
      "iterationVar": "round",
      "iterationStart": 1,
      "maxIterations": 200,
      "until": "nodes.verify.json.complete == true",
      "subgraph": [
        {
          "id": "worker",
          "type": "agent",
          "agentType": "writer",
          "model": "worker",
          "promptRef": "ralph-compound/worker.md",
          "user": "Round {{loop.round}}. 阅读 .agent-loop/spec.md 和 .agent-loop/prd.json。只实现一个未完成 story,更新 bookkeeping(prd.json passes 翻转、progress.txt 追加段落、AGENTS.md 如有学到追加),并 commit。",
          "inputs": [],
          "hooks": {
            "captureGitEvidence": true,
            "writeJudgeVerdictJson": false
          }
        },
        {
          "id": "judge",
          "type": "agent",
          "agentType": "judge",
          "model": "judge",
          "promptRef": "ralph-compound/judge.md",
          "user": "Round {{loop.round}}. 审计最新 worker round,写入 .agent-loop/judge-{{loop.round}}.md,并以 VERDICT: PASS 或 VERDICT: FAIL 结尾;如可行,同时写入结构化 .agent-loop/judge-{{loop.round}}.json(包含 verdict 字段)。",
          "inputs": ["worker"],
          "hooks": {
            "captureGitEvidence": false,
            "writeJudgeVerdictJson": true
          }
        },
        {
          "id": "verify",
          "type": "tool",
          "tool": "verifyRunCompletion",
          "args": { "round": "{{loop.round}}" },
          "inputs": ["judge"]
        }
      ]
    }
  ],
  "legacy": {
    "stateProtocolReferences": [
      ".agent-loop/progress.txt",
      ".agent-loop/judge-{{round}}.md"
    ]
  }
}
